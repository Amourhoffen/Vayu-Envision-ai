# ==========================================
# ENVISION-AI Production Environment Variables
# ==========================================

# 1. Supabase PostgreSQL (Required for Phase 1)
# Example: postgresql://postgres.xxxxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=""

# 2. Firebase Authentication (Required for Phase 1)
# Absolute path to your firebase-adminsdk.json file
FIREBASE_CREDENTIALS_JSON="./firebase-adminsdk.json"

# 3. AI Services (Required)
GEMINI_API_KEY=""

# 4. Storage & Media (Phase 2)
CLOUDINARY_URL=""

# 5. NASA Services (Phase 3)
NASA_EARTHDATA_API_KEY=""

# 6. Optional Overrides
PORT=8000
ENVIRONMENT="development"
